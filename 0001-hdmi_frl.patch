+
+    uint32_t deduct = 32 * (1 + res->audio_packets_line) + 7;
+    int32_t free_chars = (int32_t)raw_capacity - (int32_t)deduct;
+
+    if (free_chars < 0) free_chars = 0;
+
+    int32_t margin = 4;
+
+    int32_t base = free_chars - margin;
+    if (base < 0) base = 0;
+
+    res->cfrl_rc_savings = (uint32_t)((base * 7) / 8);
