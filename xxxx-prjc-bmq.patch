+static inline void check_task_changed(struct rq *rq, struct task_struct *p)
+{
+	/* Trigger resched if task sched_prio has been modified. */
+	if (task_on_rq_queued(p) && sched_task_need_requeue(p)) {
+		requeue_task(p, rq);
+		check_preempt_curr(rq);
+	}
+}
