 	raw_spin_lock_irqsave(&rq->lock, flags);
 	set_rq_offline(rq);
@@ -5453,7 +5570,7 @@ static void sched_init_topology_cpumask_early(void)
 			&(per_cpu(sched_cpu_affinity_masks, cpu)[0]);
 		per_cpu(sched_cpu_affinity_end_mask, cpu) =
