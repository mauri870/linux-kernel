+    switch (stream->timing.display_color_depth) {
+    case COLOR_DEPTH_888:    cfg.bpc = 8;  break;
+    case COLOR_DEPTH_101010: cfg.bpc = 10; break;
+    case COLOR_DEPTH_121212: cfg.bpc = 12; break;
+    case COLOR_DEPTH_161616: cfg.bpc = 16; break;
