From: Alfred Chen <cchalpha@gmail.com>
Date: Thu, 26 Feb 2026 18:40:36 +0800
Subject: [PATCH 628/631] sched/bmq: Fix BMQ deboost_task() adjustment

boost priority adjustment should only for SCHED_NORMAL or SCHED_BATCH.
---
 kernel/sched/bmq.h | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/kernel/sched/bmq.h b/kernel/sched/bmq.h
index 5a7835246ec3b..44698be032942 100644
--- a/kernel/sched/bmq.h
+++ b/kernel/sched/bmq.h
@@ -26,7 +26,8 @@ static inline void boost_task(struct task_struct *p, int n)
 
 static inline void deboost_task(struct task_struct *p)
 {
-	if (p->boost_prio < MAX_PRIORITY_ADJ)
+	if ((SCHED_NORMAL == p->policy || SCHED_BATCH == p->policy) &&
+	    p->boost_prio < MAX_PRIORITY_ADJ)
 		p->boost_prio++;
 }
 
