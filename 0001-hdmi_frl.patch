+    cfg.pixel_clock_khz = stream->timing.pix_clk_100hz / 10;
+    cfg.hactive = stream->timing.h_addressable;
+    cfg.hblank = stream->timing.h_total - stream->timing.h_addressable;
+    cfg.encoding = stream->timing.pixel_encoding;
